# FactoryDaemon — пример конфигурации окружения.
# Скопируйте в .env и заполните реальными значениями.

# ---------------------------------------------------------------
# Общие
# ---------------------------------------------------------------
FD_ENV=development
FD_LOG_LEVEL=INFO
FD_LOG_FORMAT=json
FD_PROJECT_NAME=FactoryDaemon

# ---------------------------------------------------------------
# API / HTTP-сервер
# ---------------------------------------------------------------
FD_API_HOST=0.0.0.0
FD_API_PORT=8000
FD_API_WORKERS=1
FD_API_RELOAD=false

# ---------------------------------------------------------------
# База данных
# ---------------------------------------------------------------
# Основная база. Формат URL зависит от драйвера.
# Примеры:
#   PostgreSQL: postgresql+asyncpg://user:pass@localhost:5432/factorydaemon
#   SQLite:     sqlite+aiosqlite:///./factorydaemon.db
FD_DATABASE_URL=sqlite+aiosqlite:///./factorydaemon.db

# Пул соединений (для PostgreSQL)
FD_DB_POOL_SIZE=10
FD_DB_MAX_OVERFLOW=20
FD_DB_ECHO=false

# ---------------------------------------------------------------
# Redis (для очередей, кеша, состояний агентов)
# ---------------------------------------------------------------
FD_REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------
# MCP / внешние инструменты
# ---------------------------------------------------------------
# Путь к конфигу MCP-серверов (Model Context Protocol)
FD_MCP_CONFIG_PATH=./mcp_servers.json

# ---------------------------------------------------------------
# LLM / адаптеры
# ---------------------------------------------------------------
FD_LLM_PROVIDER=ollama-cloud
FD_LLM_MODEL=qwen2.5-coder:14b
FD_LLM_BASE_URL=http://localhost:11434
FD_LLM_API_KEY=
FD_LLM_TIMEOUT=120

# ---------------------------------------------------------------
# Безопасность
# ---------------------------------------------------------------
# Секрет для внутренних токенов (сгенерируйте через `openssl rand -hex 32`)
FD_INTERNAL_SECRET=change-me-in-production

# API-ключ для внешних webhook/интеграций (опционально)
FD_WEBHOOK_API_KEY=

# ---------------------------------------------------------------
# Наблюдаемость
# ---------------------------------------------------------------
FD_METRICS_PORT=9090
FD_METRICS_PATH=/metrics

# ---------------------------------------------------------------
# Планировщик / heartbeat
# ---------------------------------------------------------------
FD_HEARTBEAT_INTERVAL_SEC=60
FD_SCHEDULER_ENABLED=true
